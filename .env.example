# ============================================
# ZapWallet Server Environment Configuration
# ============================================
# 
# SECURITY NOTICE:
# - Variables marked with ⚠️ are SECRET and should NEVER be committed to version control
# - Replace all placeholder values with actual production values
# - Keep this file secure and restrict access
#
# ============================================

# ============================================
# DATABASE & SERVER CONFIGURATION
# ============================================

# Server port (default: 5000)
# Type: Public
PORT=5000

# MongoDB connection string
# Type: SECRET ⚠️
# Example: mongodb://localhost:27017/zapwallet
# Production: mongodb+srv://username:password@cluster.mongodb.net/zapwallet
DB_URL=mongodb://localhost:27017/zapwallet

# Environment mode (development | production | test)
# Type: Public
NODE_ENV=development

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# Bcrypt salt rounds for password hashing (recommended: 12 for production)
# Type: Public
BCRYPT_SALT_ROUND=12

# JWT Access Token Secret (use strong random string)
# Type: SECRET ⚠️
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-this-in-production

# JWT Access Token Expiration (e.g., 15m, 1h, 1d)
# Type: Public
JWT_ACCESS_EXPIRES=15m

# JWT Refresh Token Secret (use different secret from access token)
# Type: SECRET ⚠️
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production

# JWT Refresh Token Expiration (e.g., 7d, 30d)
# Type: Public
JWT_REFRESH_EXPIRES=7d

# Express session secret
# Type: SECRET ⚠️
EXPRESS_SESSION_SECRET=your-express-session-secret-change-this

# ============================================
# SUPER ADMIN CREDENTIALS
# ============================================

# Default super admin email (created on first run)
# Type: SECRET ⚠️
SUPER_ADMIN_EMAIL=admin@zapwallet.com

# Default super admin password
# Type: SECRET ⚠️
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# ============================================
# OAUTH - GOOGLE AUTHENTICATION
# ============================================

# Google OAuth Client ID
# Type: SECRET ⚠️
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
# Type: SECRET ⚠️
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth Callback URL
# Type: Public
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend URL for CORS configuration
# Type: Public
# Development: http://localhost:5173
# Production: https://zapwallet.com
FRONTEND_URL=http://localhost:5173

# ============================================
# SSL COMMERZ PAYMENT GATEWAY
# ============================================

# SSL Commerz Store ID
# Type: SECRET ⚠️
# Get from: https://developer.sslcommerz.com/
SSL_STORE_ID=your-ssl-store-id

# SSL Commerz Store Password
# Type: SECRET ⚠️
SSL_STORE_PASS=your-ssl-store-password

# SSL Commerz Payment API Endpoint
# Type: Public
# Sandbox: https://sandbox.sslcommerz.com/gwprocess/v4/api.php
# Live: https://securepay.sslcommerz.com/gwprocess/v4/api.php
SSL_PAYMENT_API=https://sandbox.sslcommerz.com/gwprocess/v4/api.php

# SSL Commerz Validation API Endpoint
# Type: Public
SSL_VALIDATION_API=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php

# SSL Payment Success Redirect URL (Frontend)
# Type: Public
SSL_SUCCESS_FRONTEND_URL=http://localhost:5173/payment/success

# SSL Payment Failure Redirect URL (Frontend)
# Type: Public
SSL_FAIL_FRONTEND_URL=http://localhost:5173/payment/failed

# SSL Payment Cancel Redirect URL (Frontend)
# Type: Public
SSL_CANCEL_FRONTEND_URL=http://localhost:5173/payment/cancelled

# SSL Payment Success Callback URL (Backend)
# Type: Public
SSL_SUCCESS_BACKEND_URL=http://localhost:5000/api/v1/payment/success

# SSL Payment Failure Callback URL (Backend)
# Type: Public
SSL_FAIL_BACKEND_URL=http://localhost:5000/api/v1/payment/fail

# SSL Payment Cancel Callback URL (Backend)
# Type: Public
SSL_CANCEL_BACKEND_URL=http://localhost:5000/api/v1/payment/cancel

# SSL Instant Payment Notification URL
# Type: Public
SSL_IPN_URL=http://localhost:5000/api/v1/payment/ipn

# ============================================
# CLOUDINARY - FILE UPLOAD SERVICE
# ============================================

# Cloudinary Cloud Name
# Type: Public
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Cloudinary API Key
# Type: SECRET ⚠️
CLOUDINARY_API_KEY=your-cloudinary-api-key

# Cloudinary API Secret
# Type: SECRET ⚠️
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# EMAIL - SMTP CONFIGURATION
# ============================================

# SMTP Server Host
# Type: Public
# Gmail: smtp.gmail.com
# SendGrid: smtp.sendgrid.net
# Mailgun: smtp.mailgun.org
SMTP_HOST=smtp.gmail.com

# SMTP Server Port
# Type: Public
# TLS: 587
# SSL: 465
SMTP_PORT=587

# SMTP Username (usually your email)
# Type: SECRET ⚠️
SMTP_USER=your-email@gmail.com

# SMTP Password (use app-specific password for Gmail)
# Type: SECRET ⚠️
# Gmail: Generate at https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-specific-password

# From Email Address (sender name and email)
# Type: Public
SMTP_FROM=ZapWallet <noreply@zapwallet.com>

# ============================================
# REDIS - CACHING & SESSION STORAGE
# ============================================

# Redis Server Host
# Type: Public
# Local: localhost
# Cloud: redis-xxxxx.cloud.redislabs.com
REDIS_HOST=localhost

# Redis Server Port
# Type: Public
REDIS_PORT=6379

# Redis Username (optional, leave empty if not required)
# Type: Optional/SECRET
REDIS_USERNAME=

# Redis Password (required for cloud Redis)
# Type: SECRET ⚠️
REDIS_PASSWORD=your-redis-password

# ============================================
# OPTIONAL: TWILIO (SMS NOTIFICATIONS)
# ============================================
# Note: Twilio is installed but not configured in env.js
# Add these if you want to enable SMS notifications:

# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
#
# Before deploying to production:
# 1. Change NODE_ENV to 'production'
# 2. Use strong, unique secrets for all JWT and session keys
# 3. Use production MongoDB cluster (MongoDB Atlas recommended)
# 4. Enable SSL/TLS for all services
# 5. Use production SSL Commerz endpoints
# 6. Set up proper SMTP service (SendGrid, Mailgun, etc.)
# 7. Use managed Redis service (Redis Labs, AWS ElastiCache)
# 8. Update all URLs to production domains (HTTPS)
# 9. Enable rate limiting and security middleware
# 10. Set up monitoring and logging (Sentry, LogRocket)
#
# ============================================
